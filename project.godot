; Engine configuration file.
; It's best edited using the editor and not directly.

config_version=5

[application]
config/name="Combat Mission Companion"
run/main_scene="res://scenes/Main.tscn"

[autoload]
GameState="*res://scripts/core/GameState.gd"
UnitCatalog="*res://scripts/core/UnitCatalog.gd"
SaveManager="*res://scripts/core/SaveManager.gd"
DisplaySettings="*res://scripts/core/DisplaySettings.gd"
Rules="*res://scripts/core/Rules.gd"

[display]
window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/resizable=true
window/size/mode=0
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"


[input]

debug_toggle={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":80,"physical_keycode":80,"key_label":80,"unicode":112,"location":0,"echo":false,"script":null)
]
}
